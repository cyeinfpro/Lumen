# ============================================================================
# 本文件是 Lumen 反代最小可用配置；任何瘦身（去除 buffering off / read_timeout
# / body size）会导致 413 / SSE 断流。
#
# 关键不变量（不要随意调整）：
#   - client_max_body_size 60m   ：与 next.config 60MB 上传上限对齐
#   - proxy_buffering off        ：SSE 必需，否则前端长时间收不到事件
#   - proxy_request_buffering off：上传大图时不要先缓存到磁盘
#   - proxy_cache off            ：动态接口不缓存
#   - proxy_send_timeout 3600s   ：4K envelope 最外层（nginx 3600/1800 → arq
#                                  1800 → task 1500 → upstream 660）；瘦身回
#                                  600s 会把 4K 长任务掐断在反代层。
#   - proxy_read_timeout 1800s   ：同上，与 arq job 1800s 对齐；不要降到 600s。
#   - gzip off                   ：SSE 帧不能压缩，会破坏 event-stream
#   - HTTP/1.1 + Connection ""   ：keep-alive 复用 upstream 长连接
#   - TLS hardening              ：HSTS + TLSv1.2/1.3 + 强加密
#   - rate limit                 ：API/SSE 基础限流，防止绕过应用层限流打满 upstream
# ============================================================================

limit_req_zone $binary_remote_addr zone=lumen_api:10m rate=10r/s;
limit_req_zone $binary_remote_addr zone=lumen_events:10m rate=30r/m;

upstream lumen_web {
    # Next.js 监听本机 3000；keepalive 池保持长连接，
    # 避免每条 SSE 都重建 TCP/TLS 握手。
    server 127.0.0.1:3000;
    keepalive 32;
}

# 可选：API 直连（如果 Next.js rewrites 已经把 /api 转发到上游，这里也可以保留为空）
# upstream lumen_api {
#     server 127.0.0.1:8000;
#     keepalive 32;
# }

# HTTP -> HTTPS 强制跳转
server {
    listen 80;
    listen [::]:80;
    server_name lumen.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name lumen.example.com;

    # ----- TLS 硬化（不要降级）---------------------------------------------
    ssl_certificate     /etc/letsencrypt/live/lumen.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/lumen.example.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256;
    # `ssl_prefer_server_ciphers off`：把 cipher 选择权交给客户端，与现代浏览器 /
    # TLS 1.3 实践一致（TLS 1.3 cipher 顺序由客户端决定）。允许列表已是仅 AEAD
    # forward-secrecy cipher，客户端选哪个都安全。
    ssl_prefer_server_ciphers off;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;
    ssl_ecdh_curve      X25519:secp384r1;
    ssl_stapling        on;
    ssl_stapling_verify on;
    resolver            1.1.1.1 1.0.0.1 valid=300s;
    resolver_timeout    5s;
    # 若启用 DHE cipher，再生成并打开：
    # ssl_dhparam /etc/ssl/certs/lumen-dhparam.pem;
    limit_req_status    429;

    # HSTS：浏览器缓存一年强制 HTTPS
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header X-Frame-Options "DENY" always;
    add_header Cross-Origin-Opener-Policy "same-origin" always;
    add_header Cross-Origin-Resource-Policy "same-origin" always;
    add_header Content-Security-Policy "default-src 'self'; frame-ancestors 'none';" always;

    # ----- Body / 上传 -----------------------------------------------------
    # 与 apps/web/next.config 保持一致的 60MB 上限；瘦身到 1m/10m 会触发 413。
    client_max_body_size 60m;
    # `proxy_request_buffering off` 后请求体直接 stream 到上游，client_body_buffer_size
    # 只剩 header / 小数据缓冲意义（不影响大文件上传内存占用）；保留 8m 兼容老 nginx。
    client_body_buffer_size 8m;
    proxy_request_buffering off;

    # ----- 压缩 ------------------------------------------------------------
    # SSE event-stream 不能压缩，否则会被 nginx 缓冲到 gzip 边界才下发，
    # 导致前端 “长时间无事件 -> 一次性收到一堆” 的 buffering 表现。
    gzip off;

    # ----- 通用 proxy headers ---------------------------------------------
    proxy_http_version  1.1;
    # Connection "" 配合 keepalive 复用上游长连接（HTTP/1.1 默认 keep-alive）
    proxy_set_header    Connection        "";
    proxy_set_header    Host              $host;
    proxy_set_header    X-Real-IP         $remote_addr;
    proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header    X-Forwarded-Proto $scheme;
    proxy_set_header    X-Forwarded-Host  $host;

    # 连接 / 读 / 写 超时
    # 4K envelope 最外层：nginx 3600/1800 → arq 1800 → task 1500 → upstream 660；
    # 顺序绝对不能反——内层提前 timeout，外层才有机会感知失败并 surface 给前端。
    proxy_connect_timeout 30s;
    proxy_send_timeout    3600s;  # 大图上传 / 长 SSE 写入；与 server 块默认 envelope 对齐
    proxy_read_timeout    1800s;  # 与 arq job timeout 1800s 对齐；不要降到 600s

    # ----- /events SSE 专用 location（必须最先匹配）------------------------
    # 这一段是 Lumen 的核心数据通路，任何 buffering / cache / 压缩都不能开。
    location /events {
        limit_req               zone=lumen_events burst=10 nodelay;
        proxy_pass              http://lumen_web;
        proxy_http_version      1.1;
        proxy_set_header        Connection        "";
        proxy_set_header        Host              $host;
        proxy_set_header        X-Real-IP         $remote_addr;
        proxy_set_header        X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header        X-Forwarded-Proto $scheme;

        # SSE 三件套：不能改 / 不能瘦身
        proxy_buffering         off;
        proxy_cache             off;
        proxy_request_buffering off;

        # SSE 长连接：浏览器侧 30~60min 不应被反代切断
        # 4K envelope: nginx 3600/1800 → arq 1800 → task 1500 → upstream 660
        proxy_connect_timeout   30s;
        proxy_send_timeout      3600s;
        proxy_read_timeout      1800s;

        # 让上游和中间代理都明确知道这是长连接流；核心仍是 proxy_buffering off。
        proxy_set_header        X-Accel-Buffering no;
        add_header              Cache-Control "no-cache" always;
        add_header              X-Accel-Buffering no always;
        # SSE 使用 chunked transfer；不能被缓存或 gzip。
        chunked_transfer_encoding on;
    }

    # ----- /api 后端 ------------------------------------------------------
    location /api/ {
        limit_req               zone=lumen_api burst=30 nodelay;
        proxy_pass              http://lumen_web;
        proxy_buffering         off;
        proxy_cache             off;
        proxy_request_buffering off;
        # 4K envelope: nginx 3600/1800 → arq 1800 → task 1500 → upstream 660；
        # admin 后端的同步任务（regenerate / 4K render）会沿 /api/ 进入。
        proxy_connect_timeout   30s;
        proxy_send_timeout      3600s;
        proxy_read_timeout      1800s;
    }

    # ----- /api/images 二进制 sendfile hand-off（可选优化）---------------
    # lumen-api 在 LUMEN_INTERNAL_REDIRECT_ENABLED=1 时，对 /api/images/*/binary
    # 和 /api/images/*/variants/* 这类请求只返 X-Accel-Redirect 头，bytes 由
    # nginx native sendfile + open_file_cache 直接读 storage 返回。Python 进程
    # 完全不打开文件，CIFS 读速 + Python streaming 都不再是瓶颈。
    #
    # alias 路径必须等于 LUMEN_DATA_ROOT/storage（单机部署默认 /opt/lumendata/storage）。
    # internal 指令禁止外部直接访问；下面的 regex 白名单只允许当前 image storage
    # key 形态（u/<user>/...），其它内部跳转一律 404，作为 API path 校验之外的
    # nginx 侧 auth fence。
    #
    # 不开 LUMEN_INTERNAL_REDIRECT_ENABLED 时这段也无害——lumen-api 走 streaming
    # fallback，nginx 永远不会发请求到这个 internal location。
    # storage key 字符白名单不放 `~`，避免 CIFS 上 `.snapshot` / `.recycled` /
    # `~$tilde` 等隐藏目录被 internal alias 读到（Lumen 自己生成的 storage_key
    # 形态是 `u/<uuid>/...`，不含 `~`，去掉是安全的紧法）。
    location ~ ^/_internal_storage/(?<storage_path>u/(?!.*\.\.)[A-Za-z0-9._/-]+)$ {
        internal;
        alias /opt/lumendata/storage/$storage_path;
        disable_symlinks        on from=/opt/lumendata/storage;

        sendfile                on;
        sendfile_max_chunk      1m;
        tcp_nopush              on;
        # open_file_cache 让重复访问的热图省一次 stat() — 对灵感流场景收益大。
        open_file_cache         max=2000 inactive=10m;
        open_file_cache_valid   30s;
        open_file_cache_min_uses 2;
        open_file_cache_errors  off;

        # immutable variants 让浏览器长缓存，CIFS 读速也不再被反复触发。
        # lumen-api 已经在响应里带了 Cache-Control / ETag；nginx 不要覆盖它们，
        # 也不要再次 gzip（image variants 全是 jpeg/webp，再压无效）。不要在本
        # location 重复 add_header；否则 nginx 会停止继承 server 级安全头。
        gzip                    off;
    }

    location /_internal_storage/ {
        internal;
        return 404;
    }

    # ----- Next.js 静态资源 / 页面 ----------------------------------------
    location / {
        proxy_pass              http://lumen_web;
        # 默认 location 也对齐 4K envelope（Next.js rewrites 会把 /api/* 转到上游）
        proxy_connect_timeout   30s;
        proxy_send_timeout      3600s;
        proxy_read_timeout      1800s;
        # 页面响应允许 nginx buffer（非 SSE / 非上传）
        proxy_buffering         on;
    }
}
