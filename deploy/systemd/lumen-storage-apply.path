[Unit]
Description=Lumen storage apply trigger watcher
After=multi-user.target

[Path]
# lumen-api (containerised) writes this file via PUT /admin/storage; PID 1 starts
# lumen-storage-apply.service so we sidestep the container's sandbox/sudo chain.
PathChanged=/var/lib/lumen-storage/apply.trigger
Unit=lumen-storage-apply.service

[Install]
WantedBy=multi-user.target
