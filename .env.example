# Copy to .env and fill every blank secret before deployment.
# 后端 (apps/api, apps/worker) 通过 pydantic-settings 自动加载 .env。
# 前端 (apps/web) 通过 Next.js 的 .env.local 独立配置。

# 本 .env 默认面向 docker-compose 全栈部署：DATABASE_URL / REDIS_URL / LUMEN_BACKEND_URL
# 均使用容器 service 名（postgres / redis / api），仅在 compose 网络内可解析。
# 如果从宿主机直接执行 alembic 或本地脚本（参见 §9.3），需临时把 host 改回 127.0.0.1。

# --- Docker 镜像源 (§6.4 / §10.5) ---
LUMEN_IMAGE_REGISTRY=ghcr.io/cyeinfpro
LUMEN_IMAGE_TAG=latest
LUMEN_UPDATE_CHANNEL=stable
# docker-compose 中 api/worker 仍会读取完整 env 文件；CI 可改成 .env.ci。
LUMEN_COMPOSE_ENV_FILE=.env
# 如需追踪 main 分支更新，把上面两行改为：
# LUMEN_IMAGE_TAG=main
# LUMEN_UPDATE_CHANNEL=main
# 文件/备份根目录；storage/backup 在它下面，可指向 CIFS/NAS。
LUMEN_DATA_ROOT=/opt/lumendata
# 数据库根目录；postgres/redis 在它下面。默认跟随 LUMEN_DATA_ROOT。
# 如果 LUMEN_DATA_ROOT 是 CIFS/NAS，建议把这里设为本机 Linux 文件系统路径。
LUMEN_DB_ROOT=/opt/lumendata
# 应用容器运行身份。默认匹配镜像内置 lumen 用户；CIFS/NAS 场景如挂载目录
# forcegid 到宿主机 lumen 组，可只把 LUMEN_APP_STORAGE_GID 设为对应 gid。
LUMEN_APP_UID=10001
LUMEN_APP_GID=10001
LUMEN_APP_STORAGE_GID=10001
# 国内访问 GitHub/GHCR 受阻时填代理；install/update/面板一键更新都会自动读取
# LUMEN_HTTP_PROXY 和 LUMEN_UPDATE_PROXY_URL 任填一个即可。
# LUMEN_UPDATE_PROXY_URL=http://127.0.0.1:7890
# LUMEN_HTTP_PROXY=http://127.0.0.1:7890
# 模特库同步拉取 GitHub 预设时，也可使用代理池（名称需存在于 PROVIDERS.proxies）。
# APPAREL_MODEL_LIBRARY_SYNC_USE_PROXY_POOL=0
# APPAREL_MODEL_LIBRARY_SYNC_PROXY_NAME=

# 如果反代 nginx 配了 `location /_internal_storage/`（参见
# deploy/nginx.conf.example），可以打开下面这一行让 lumen-api 把 image
# binary / variant 的下载交给 nginx native sendfile，Python 进程不再开文件。
# 对 CIFS/NAS storage 提速明显，弱网络场景体感最显著。默认关闭——没改 nginx
# 不要打开（开了 nginx 不会处理 X-Accel-Redirect，会返 404）。
# LUMEN_INTERNAL_REDIRECT_ENABLED=1

# --- Database / Cache ---
# docker-compose 要求这些变量显式存在；留空会 fail-fast，避免示例密码被部署。
# 可用 `openssl rand -hex 32` 生成 DB_PASSWORD / REDIS_PASSWORD。
#
# DATABASE_URL / REDIS_URL：
#   - docker-compose 部署：留空，模板会从 DB_USER/DB_PASSWORD/DB_NAME 和
#     REDIS_PASSWORD 自动推导（host=postgres / redis，仅 compose 网络内可解析）。
#   - **systemd / 裸金属部署：必填**——没有 compose 推导，留空会让 alembic
#     和 worker 启动时直接报 "DATABASE_URL not set"。下面给出本机 fallback 示例。
#   - 密码含 URL 特殊字符（@ : / ?）时也必须手动 URL-encode 后填这两行。
DB_USER=lumen_app
DB_PASSWORD=
DB_NAME=lumen_app
# 例：DATABASE_URL=postgresql+asyncpg://lumen_app:CHANGE_ME@127.0.0.1:5432/lumen_app
DATABASE_URL=
REDIS_PASSWORD=
# 注意：REDIS_URL 包含密码；绝不要在日志、命令输出或日志聚合系统中暴露此变量。
# 应用和脚本应确保这个变量不被打印、不被发送到日志聚合系统。
# 例：REDIS_URL=redis://:CHANGE_ME@127.0.0.1:6379/0
REDIS_URL=
# Postgres/Redis 由 docker-compose 启动时不再映射到 host；调试用 docker exec 进容器。
API_BIND_HOST=127.0.0.1
# Web 默认对外监听 3000；如只允许 nginx 本机反代，可改成 127.0.0.1。
WEB_BIND_HOST=0.0.0.0

# --- Provider Pool（上游配置唯一入口）---
PROVIDERS=[]
# 带代理的新格式示例：
# PROVIDERS={"proxies":[{"name":"s5-us","type":"socks5","host":"127.0.0.1","port":1080}],"providers":[{"name":"default","base_url":"https://api.example.com","api_key":"sk-xxx","proxy":"s5-us","priority":0,"weight":1,"enabled":true}]}
# SSH 密码代理示例（启动时会本地拉起 SSH dynamic SOCKS 隧道）：
# PROVIDERS={"proxies":[{"name":"ssh-cn","type":"ssh","host":"203.0.113.10","port":22,"username":"root","password":"replace-with-ssh-password"}],"providers":[{"name":"default","base_url":"https://api.example.com","api_key":"sk-xxx","proxy":"ssh-cn","priority":0,"weight":1,"enabled":true}]}
# 默认模型 id（runtime_settings.SUPPORTED_SETTINGS 中 upstream.default_model 的 env fallback）
UPSTREAM_DEFAULT_MODEL=gpt-5.5
# 对话 file_search 默认向量库 id，多个用英文逗号分隔；也可由请求 chat_params.vector_store_ids 覆盖/补充。
CHAT_FILE_SEARCH_VECTOR_STORE_IDS=
# 像素预算上限（默认与 constants.PIXEL_BUDGET 一致）
UPSTREAM_PIXEL_BUDGET=1572864
# 全局上游并发上限（1-100）
UPSTREAM_GLOBAL_CONCURRENCY=4
# 图片统一任务队列并发。所有 1K/2K/4K 共用；并发中的两张会分配到不同 Provider。
IMAGE_GENERATION_CONCURRENCY=2

# --- Session / Auth ---
# 生成命令：openssl rand -hex 64
SESSION_SECRET=
# 简化版会话有效期 (分钟)；DESIGN §9.1 的 refresh token rotation 在 V1.1+ 落地
SESSION_TTL_MIN=10080

# --- App ---
APP_ENV=dev
APP_PORT=8000
# 对象存储根目录（V1 先用 fs；生产换 S3）；部署默认使用明确绝对路径。
STORAGE_ROOT=/opt/lumendata/storage
# 暴露给前端的公开 base URL (图像反代)
PUBLIC_BASE_URL=http://localhost:8000
# 允许浏览器跨域访问 API 的前端来源，逗号分隔
CORS_ALLOW_ORIGINS=http://localhost:3000
# 允许信任 X-Forwarded-For 的直连代理 IP/CIDR，逗号分隔；为空则完全忽略 XFF。
TRUSTED_PROXIES=
# 本次部署的版本标识（注入到上游 HTTP originator header，便于上游侧定位流量与回查问题）。
# 部署时请用 deploy/scripts/sync_env_version.sh 自动写入当前 git commit 短 hash；
# 不写则 fallback 为 "lumen-prod-unknown"。
LUMEN_VERSION=unknown

# --- API tuning (仅 docker-compose 生效；裸跑 uvicorn 时由各自命令行参数覆盖) ---
# 这些变量在 docker-compose.yml 的 api.command 里被引用；改 .env 即可调优 worker 数与
# 超时上限，不必动 compose 文件。注释掉走默认值（与 §6.4.1 envelope 对齐）。
# LUMEN_API_WORKERS=2
# LUMEN_API_TIMEOUT_KEEP_ALIVE=60
# LUMEN_API_TIMEOUT_GRACEFUL_SHUTDOWN=30
# LUMEN_API_TIMEOUT_WORKER_HEALTHCHECK=10
# LUMEN_API_LIMIT_MAX_REQUESTS=10000
# LUMEN_API_LIMIT_MAX_REQUESTS_JITTER=1000

# --- Observability (可选) ---
# 留空则关闭。Sentry / OTEL 见 apps/api/app/config.py。
# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Migration / 启动门禁 ---
# 启动期会比对 DB 与 alembic head；prod 不在 head 直接拒启，dev 仅 warn。
# 测试 / 离线脚本如不需该检查，置为 1 跳过。
# LUMEN_SKIP_MIGRATION_CHECK=0

# --- Frontend ---
# Next.js 服务端 rewrite 的后端地址；远端部署时指向目标服务器上的 API 服务。
LUMEN_BACKEND_URL=http://api:8000
# 浏览器侧默认走同源 /api，由 Next.js rewrites 或外层反代转发。
# 跨域 / 子域部署时再改成 API 公网域名，例如 https://api.example.com。
NEXT_PUBLIC_API_BASE=/api

# --- Telegram Bot 集成（apps/tgbot） ---
# bot ↔ api 的共享密钥；非 dev 必须 ≥32 字符。留空则 /telegram/* 全部 401。
TELEGRAM_BOT_SHARED_SECRET=
# 以下只有 bot 进程读，api 不需要：
# TELEGRAM_BOT_TOKEN=123456789:REPLACE_WITH_BOT_TOKEN        # @BotFather 拿到的
# TELEGRAM_BOT_USERNAME=LumenBot               # 不带 @，用于拼 deep_link
# bot 调 api 的内网地址；docker-compose 默认走 service 名 api
LUMEN_API_BASE=http://api:8000
# REDIS_URL 已在上面定义；bot 复用同一实例订阅 PubSub
# BOT_MODE=polling                              # polling | webhook（webhook 需配 nginx 反代）
