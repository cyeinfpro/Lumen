{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumen",
  "version": "1.2.32",
  "identifier": "com.lumen.desktop",
  "build": {
    "frontendDist": "dist/web",
    "devUrl": "http://127.0.0.1:3000",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Lumen",
        "width": 1280,
        "height": 820,
        "minWidth": 880,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:*; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' data: blob: http://127.0.0.1:*; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'",
      "capabilities": [
        "main-desktop-bridge",
        "main-startup-bridge"
      ]
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Lumen",
    "copyright": "Copyright (c) 2026 Lumen",
    "shortDescription": "Lumen desktop",
    "longDescription": "Lumen desktop app for local macOS and Windows runtime management.",
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/alembic/desktop/**/*",
      "resources/runtime/**/*",
      "resources/web/**/*",
      "resources/licenses/**/*"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "packaging/scripts/lumen.entitlements"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false,
        "installerHooks": "windows/hooks.nsh",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://github.com/cyeinfpro/Lumen/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
