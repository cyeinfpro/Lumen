{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-startup-bridge",
  "description": "Allow the bundled local startup page to inspect and recover the desktop runtime before the loopback web UI is ready.",
  "local": true,
  "windows": ["main"],
  "permissions": [
    "allow-desktop-startup-status",
    "allow-export-diagnostics-bundle",
    "allow-open-data-dir",
    "allow-restart-desktop-app",
    "allow-retry-desktop-startup"
  ]
}
